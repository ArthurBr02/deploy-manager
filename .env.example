# Base de données
DB_URL=jdbc:postgresql://localhost:5432/deploymanager
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT — CHANGEZ CES VALEURS EN PRODUCTION
JWT_ACCESS_SECRET=very-long-secret-key-for-access-token-please-change-in-production
JWT_REFRESH_SECRET=very-long-secret-key-for-refresh-token-please-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Premier compte admin (créé au démarrage si aucun admin n'existe)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234!

# Répertoire des logs de déploiement
LOG_DIR=./logs/deployments

# SMTP (optionnel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
